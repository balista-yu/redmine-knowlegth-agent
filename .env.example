# =============================================================================
# Redmine Knowledge Agent - 環境変数サンプル
# 詳細: docs/01-design.md §9
#
# 使い方: `cp .env.example .env` してから値を埋める。`.env` は git 管理外。
# =============================================================================

# --- Ollama (本リポジトリ管理外。事前にホストで起動しておく) ---
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_LLM_MODEL=qwen3.5:9b
OLLAMA_EMBED_MODEL=nomic-embed-text

# --- Redmine ---
REDMINE_BASE_URL=http://redmine:3000
# Redmine 初回ログイン後に発行された REST API キーを設定する
REDMINE_API_KEY=

# --- Qdrant (gRPC) ---
QDRANT_HOST=qdrant
QDRANT_PORT=6334
QDRANT_COLLECTION=redmine_tickets

# --- 同期メタデータ DB (PostgreSQL) ---
APP_DB_URL=jdbc:postgresql://app-db:5432/redmineagent
APP_DB_USER=redmineagent
APP_DB_PASSWORD=

# --- スケジューラ (cron 式) ---
SYNC_CRON=0 0 * * * *
RECONCILE_CRON=0 0 3 * * SUN
